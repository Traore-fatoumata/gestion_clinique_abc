# ═══════════════════════════════════════════════
#  CONFIGURATION — Clinique ABC Marouane Backend
#  Copiez ce fichier en .env et adaptez les valeurs
# ═══════════════════════════════════════════════

# Serveur
PORT=5000
NODE_ENV=development

# PostgreSQL — adaptez avec vos infos locales
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinique_marouane
DB_USER=postgres
DB_PASSWORD=fatim

# JWT — changez en production avec une clé longue et aléatoire
JWT_SECRET=clinique_marouane_super_secret_jwt_key_2026
JWT_EXPIRES_IN=8h

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
